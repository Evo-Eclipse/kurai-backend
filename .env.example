# -- Required: Secrets -------------------------------------------------
KURAI_JWT_SECRET=

# -- Required: Unsplash ------------------------------------------------
KURAI_UNSPLASH_ACCESS_KEY=
KURAI_UNSPLASH_USER_AGENT=kurai/1

# -- Required: E621 ----------------------------------------------------
KURAI_E621_USER_AGENT=kurai/1
KURAI_E621_USERNAME=
KURAI_E621_ACCESS_KEY=

# -- Required: Paths ---------------------------------------------------
KURAI_SQLITE_PATH=/var/lib/kurai/kurai.db
KURAI_LUCENE_DIR=/var/lib/kurai/lucene
KURAI_OBJECT_STORE_DIR=/var/lib/kurai/objects

# -- Required: ML model ------------------------------------------------
KURAI_ONNX_MODEL_PATH=/var/lib/kurai/dinov3-vitb16_224_int8.onnx
KURAI_ONNX_MODEL_SHA256=
KURAI_CLUSTERS_PATH=/var/lib/kurai/dinov3-vitb16_centroids.bin

# -- Optional: Auth ----------------------------------------------------
# KURAI_AUTH_JWT_TTL_MS=86400000
# KURAI_AUTH_SESSION_TTL_MS=2592000000
# KURAI_AUTH_CHALLENGE_TTL_MS=600000
KURAI_ADMIN_TOKEN=
KURAI_AUTH_STRICT_REUSE=false

# -- Optional: Rate limiting -------------------------------------------
# KURAI_KEY_ISSUE_RATE_LIMIT_MAX=10
# KURAI_KEY_ISSUE_RATE_LIMIT_WINDOW_MS=60000

# -- Optional: Session GC ----------------------------------------------
# KURAI_SESSION_GC_INTERVAL_MS=3600000
# KURAI_SESSION_GC_RETENTION_MS=86400000

# -- Optional: Content -------------------------------------------------
# KURAI_CONTENT_MAX_IMAGES=30
# KURAI_CONTENT_MAX_IMAGE_BYTES=10485760

# -- Optional: Network -------------------------------------------------
KURAI_TRUSTED_PROXY=false
KURAI_CORS_ALLOWED_ORIGINS=

# -- Optional: ML tuning -----------------------------------------------
# KURAI_ONNX_INTRA_OP_THREADS=2
# KURAI_ONNX_INFERENCE_PARALLELISM=1
# KURAI_PROFILE_PERSIST_INTERVAL_MS=30000
# KURAI_KMEANS_CHECK_INTERVAL_MS=3600000

# -- Optional: OpenTelemetry -----------------------------------------------
# KURAI_OTEL_SERVICE_NAME=kurai-backend
# KURAI_OTEL_EXPORTER=none
KURAI_OTEL_OTLP_ENDPOINT=
KURAI_OTEL_OTLP_HEADERS=
# KURAI_OTEL_METRIC_INTERVAL_MS=60000

# -- Development ---------------------------------------------------------
KURAI_AUTH_MAIL_STUB=true
